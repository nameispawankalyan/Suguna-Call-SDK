<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_leave_dialog"
    android:padding="26dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Suguna Chat Room"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose how you want to continue"
        android:textColor="#A0FFFFFF"
        android:textSize="13sp"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:textAllCaps="true"
        android:letterSpacing="0.1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="28dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMinimize"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Minimize to Background"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2196F3"
            app:cornerRadius="16dp"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            app:rippleColor="#40FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeave"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Leave &amp; Close Room"
            android:textColor="#FFFFFF"
            app:backgroundTint="#33FFFFFF"
            app:cornerRadius="16dp"
            android:textAllCaps="false"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKeep"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="32dp"
            android:text="Stay in Room"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1AFFFFFF"
            app:cornerRadius="16dp"
            android:textAllCaps="true"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            app:strokeWidth="1dp"
            app:strokeColor="#20FFFFFF"/>
            
    </LinearLayout>
</LinearLayout>
