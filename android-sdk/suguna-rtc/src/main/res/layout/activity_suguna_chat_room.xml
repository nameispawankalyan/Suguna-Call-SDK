<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/suguna_chat_bg"
    android:fitsSystemWindows="true">

    <!-- Top Theme Container (Header & Seats) -->
    <LinearLayout
        android:id="@+id/topThemeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#00000000"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivRoomOwner"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="12dp"
                android:src="@android:color/darker_gray"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedSoft" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRoomName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suguna Chat Room"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <LinearLayout
                    android:id="@+id/btnOnlineCountSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#4CAF50"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/tvOnlineCountSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Online: 1"
                        android:textColor="#B0BEC5"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRoomId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: --"
                    android:textColor="#B0BEC5"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Online Button -->
            <LinearLayout
                android:id="@+id/btnOnlineCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_rounded_chat_input"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="#FFFFFF"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvOnlineCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Requests Counter / View (For Host) -->
            <LinearLayout
                android:id="@+id/btnViewRequests"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_rounded_chat_input"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvRequestCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requests (0)"
                    android:textColor="#FF9800"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/more_vert_icon"
                android:tint="#FFFFFF"/>
        </LinearLayout>

        <!-- Seats Container (Recycler View) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSeats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            tools:listitem="@layout/item_chat_room_seat"/>
    </LinearLayout>

    <!-- Bottom Theme Container (Messages & Controls) -->
    <LinearLayout
        android:id="@+id/bottomThemeContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/bg_messages_card"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/topThemeContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Messages Container (Recycler View) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            tools:listitem="@layout/item_chat_room_message"/>

        <!-- Music Player Overlay -->
        <include
            android:id="@+id/musicOverlay"
            layout="@layout/layout_music_player_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <!-- Bottom Action Bar (Chat Input & Mute Buttons) -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_rounded_chat_input"
                android:hint="Type a message..."
                android:textColorHint="#AFFFFFFF"
                android:textColor="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:inputType="text"/>

            <ImageButton
                android:id="@+id/btnMusicSelection"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:padding="11dp"
                android:src="@drawable/music_note_icon"
                android:background="@drawable/bg_circle_reaction"
                android:visibility="gone"
                android:layout_marginStart="8dp"
                app:tint="#00E5FF"/>

            <ImageButton
                android:id="@+id/btnReactions"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:padding="11dp"
                android:src="@drawable/mood_icon"
                android:background="@drawable/bg_circle_reaction"
                android:visibility="visible"
                android:layout_marginStart="8dp"
                app:tint="#FFEB3B"/>

            <ImageButton
                android:id="@+id/btnSendMessage"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_circle_send"
                android:src="@drawable/ic_send_rounded"
                app:tint="#FFFFFF"
                android:padding="11dp"
                android:layout_marginStart="10dp"
                android:elevation="4dp"
                android:scaleType="centerInside"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/btnRequestSeat"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="#25D366"
        android:src="@android:drawable/ic_input_add"
        app:tint="#FFFFFF"
        android:padding="16dp"
        app:shapeAppearanceOverlay="@style/CircleImage"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:visibility="gone"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
